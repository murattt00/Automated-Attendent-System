{
  "name": "university-attendance-backend",
  "version": "1.0.0",
  "description": "University Attendance System - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "migrate:status": "npx sequelize-cli db:migrate:status",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo:all",
    "test-setup": "node scripts/test-setup.js"
  },
  "keywords": [
    "attendance",
    "qr-code",
    "real-time",
    "socket.io"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-rate-limit-redis": "^1.0.2",
    "geolib": "^3.3.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.2.0",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "rate-limit-redis": "^4.2.0",
    "sequelize": "^6.31.0",
    "socket.io": "^4.6.1",
    "vue-chartjs": "^5.3.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "sequelize-cli": "^6.6.2"
  }
}
