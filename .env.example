# ===========================================
# UNIVERSITY ATTENDANCE SYSTEM - ENVIRONMENT VARIABLES
# ===========================================
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit .env file to git!
# ===========================================

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=university_attendance
DB_USER=root
DB_PASSWORD=your_secure_password_here
# Connection pool settings
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave empty if no password
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3001
NODE_ENV=development
# production, development, staging
HOST=0.0.0.0

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# CRITICAL: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MUST be at least 64 characters for production!
JWT_SECRET=REPLACE_WITH_64_PLUS_CHAR_RANDOM_STRING_USE_CRYPTO_RANDOMBYTES_FOR_PRODUCTION
JWT_EXPIRES_IN=7d
# Token expiry: 7d, 24h, 1h, etc.

# ===========================================
# FRONTEND URL (CORS)
# ===========================================
FRONTEND_URL=http://localhost:3000
# For production: https://yourdomain.com
# For network access: http://192.168.1.x:3000

# ===========================================
# QR TOKEN CONFIGURATION
# ===========================================
# Token expiry in milliseconds (30 seconds)
QR_TOKEN_EXPIRY=30000
# Token rotation interval in milliseconds (30 seconds - MUST match frontend countdown)
QR_ROTATION_INTERVAL=30000

# ===========================================
# LOCATION VERIFICATION
# ===========================================
# Maximum allowed distance in meters
MAX_DISTANCE_METERS=100

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
# Levels: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# ===========================================
# RATE LIMITING
# ===========================================
# General rate limit (15 minutes window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Auth endpoints (stricter)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5
# Attendance endpoints
ATTENDANCE_RATE_LIMIT_WINDOW_MS=60000
ATTENDANCE_RATE_LIMIT_MAX=30

# ===========================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# For Gmail: Use App Password, not regular password
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=University Attendance <noreply@university.edu>

# ===========================================
# SECURITY HEADERS (Helmet.js)
# ===========================================
# Enable/disable specific security features
HELMET_CSP_ENABLED=false
# Disable CSP if using Socket.IO on different domains
HELMET_HSTS_ENABLED=true
HELMET_HSTS_MAX_AGE=31536000

# ===========================================
# SESSION CONFIGURATION
# ===========================================
# Auto-end inactive sessions after X minutes
SESSION_AUTO_END_MINUTES=480
# 8 hours default

# ===========================================
# FILE UPLOAD (Future feature)
# ===========================================
MAX_FILE_SIZE=5242880
# 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# ===========================================
# MONITORING & ANALYTICS (Optional)
# ===========================================
SENTRY_DSN=
# Sentry error tracking DSN
GA_TRACKING_ID=
# Google Analytics tracking ID

# ===========================================
# FEATURE FLAGS (Optional - for gradual rollout)
# ===========================================
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_FACIAL_RECOGNITION=false
FEATURE_REPORTS_EXPORT=true
FEATURE_ANALYTICS_DASHBOARD=true

# ===========================================
# DEVELOPMENT ONLY
# ===========================================
# Enable detailed SQL query logging (development only!)
DB_LOGGING=false
# Enable debug mode
DEBUG=false

